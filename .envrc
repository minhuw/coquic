# CoQUIC RAG demo credentials.
# Keep real secrets in .envrc.local; it is ignored by git.

export OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"
export COQUIC_QDRANT_URL="${COQUIC_QDRANT_URL:-}"
export COQUIC_QDRANT_API_KEY="${COQUIC_QDRANT_API_KEY:-}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}"

if [ -f .envrc.local ]; then
  source_env .envrc.local
fi
